{
  "manifest_version": 2,
  "version": "1.0",
  "name": "Fenix Threat Meta",
  "description": "Dark Firefox theme using Rift Rose for combat, pressure, and meta-threat emphasis.",
  "theme": {
    "colors": {
      "frame": "#100B15",
      "frame_inactive": "#0C0911",
      "toolbar": "#1B1226",
      "toolbar_text": "#D6C8EA",
      "toolbar_field": "#35151E",
      "toolbar_field_text": "#E7DCF5",
      "toolbar_field_border": "#4B3764",
      "toolbar_field_border_focus": "#FB7185",
      "toolbar_top_separator": "#2E203D",
      "toolbar_bottom_separator": "#35151E",
      "toolbar_vertical_separator": "#2E203D",
      "tab_background_text": "#A99ABF",
      "tab_selected": "#27173A",
      "tab_text": "#E7DCF5",
      "tab_line": "#FB7185",
      "tab_loading": "#FB7185",
      "popup": "#27173A",
      "popup_text": "#D6C8EA",
      "popup_border": "#35151E",
      "popup_highlight": "#35151E",
      "popup_highlight_text": "#FB7185",
      "icons": "#A99ABF",
      "icons_attention": "#FB7185",
      "button_background_hover": "#21152F",
      "button_background_active": "#35151E"
