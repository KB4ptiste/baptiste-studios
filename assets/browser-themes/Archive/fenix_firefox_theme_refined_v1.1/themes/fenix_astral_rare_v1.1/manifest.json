  "theme": {
    "colors": {
      "frame": "#150A24",
      "frame_inactive": "#12091C",
      "toolbar": "#1B1226",
      "toolbar_text": "#D6C8EA",
      "toolbar_field": "#32173A",
      "toolbar_field_text": "#E7DCF5",
      "toolbar_field_border": "#4B3764",
      "toolbar_field_border_focus": "#E879F9",
      "toolbar_top_separator": "#2E203D",
      "toolbar_bottom_separator": "#32173A",
      "toolbar_vertical_separator": "#2E203D",
      "tab_background_text": "#A99ABF",
      "tab_selected": "#27173A",
      "tab_text": "#E7DCF5",
      "tab_line": "#E879F9",
      "tab_loading": "#E879F9",
      "popup": "#27173A",
      "popup_text": "#D6C8EA",
      "popup_border": "#32173A",
