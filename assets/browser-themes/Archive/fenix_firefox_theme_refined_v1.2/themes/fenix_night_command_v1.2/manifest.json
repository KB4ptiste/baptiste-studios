{
  "manifest_version": 2,
  "version": "1.2",
  "name": "Fenix Night Command",
  "description": "Core dark Firefox theme using the Fenix Gaming Night Command palette with Black Violet browser chrome.",
  "theme": {
    "colors": {
      "frame": "#150A24",
      "frame_inactive": "#12091C",
      "toolbar": "#1B1226",
      "toolbar_text": "#D6C8EA",
      "toolbar_field_text": "#D6C8EA",
      "toolbar_field_border": "#4B3764",
      "toolbar_top_separator": "#2E203D",
      "toolbar_bottom_separator": "#4B3764",
      "toolbar_vertical_separator": "#2E203D",
      "tab_background_text": "#A99ABF",
      "tab_selected": "#27173A",
      "tab_text": "#E7DCF5",
      "popup": "#27173A",
      "popup_text": "#D6C8EA",
      "popup_border": "#4B3764",
      "popup_highlight_text": "#E7DCF5",
      "icons": "#A99ABF",
      "button_background_hover": "#21152F",
